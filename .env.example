# Server
PORT=8080
NODE_ENV=development
# Comma-separated list of allowed browser origins (Angular dev server, prod domain)
CORS_ORIGINS=http://localhost:4200

# Supabase — from your project's API settings (Project Settings → API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Public anon key — safe to expose; used to verify user JWTs
SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Service role key — SECRET, server-only. Grants full DB access (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Optional: Alpha Vantage key for the global-stocks feature (free tier: 25 req/day)
# Get one at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=75N2QOG6QMOY5G1T

# Optional: secret to authorize POST /api/admin/refresh (re-scrape on demand).
# If unset, the endpoint is disabled.
ADMIN_KEY=

# Optional: Firebase service-account for sending bill-alert push (FCM).
# The ENTIRE service-account JSON, on ONE line. Generate at:
#   Firebase console -> Project settings -> Service accounts -> Generate new private key
# Easiest way to produce the one-line value (from the downloaded file):
#   node -e "console.log(JSON.stringify(require('./fcm-key.json')))"
# Leave empty to keep bill-alert push dormant (connections still save; no send).
FCM_SERVICE_ACCOUNT={"type":"service_account","project_id":"roznama-bilal-68b4e","private_key_id":"REPLACE_ME","private_key":"-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-XXXXX@roznama-bilal-68b4e.iam.gserviceaccount.com","client_id":"REPLACE_ME","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"REPLACE_ME","universe_domain":"googleapis.com"}
